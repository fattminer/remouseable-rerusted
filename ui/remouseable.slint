import { VerticalBox, HorizontalBox, Slider } from "std-widgets.slint";

// Text inputs use a custom wrapper so text and placeholder colors remain readable
// across Slint themes and OS palette choices.
component ReadableLineEdit inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder-text;
    in property <InputType> input-type: InputType.text;
    callback accepted();

    height: 36px;
    min-width: 160px;
    background: #18181b;
    border-color: input.has-focus ? #d4d4d8 : #52525b;
    border-width: 1px;
    border-radius: 4px;
    clip: true;

    // Placeholder text is drawn separately because TextInput does not provide a
    // directly styleable placeholder color.
    Text {
        x: 10px;
        y: 0px;
        width: parent.width - 20px;
        height: parent.height;
        text: root.text == "" ? root.placeholder-text : "";
        color: #71717a;
        vertical-alignment: center;
    }

    // Actual editable field. Two-way binding lets Rust read latest UI values
    // without extra synchronization code.
    input := TextInput {
        x: 10px;
        y: 0px;
        width: parent.width - 20px;
        height: parent.height;
        text <=> root.text;
        input-type: root.input-type;
        color: #f4f4f5;
        selection-foreground-color: #09090b;
        selection-background-color: #d4d4d8;
        vertical-alignment: center;
        accepted => { root.accepted(); }
    }
}

// Small hand-built combobox for tablet orientation. The standard ComboBox keeps
// selected text color theme-owned, so this draws selected text explicitly.
component OrientationCombo inherits Rectangle {
    in-out property <string> value;

    height: 36px;
    min-width: 160px;
    background: #18181b;
    border-color: #52525b;
    border-width: 1px;
    border-radius: 4px;

    // Whole closed control opens the popup, matching normal combobox behavior.
    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { popup.show(); }
    }

    Text {
        x: 10px;
        y: 0px;
        width: parent.width - 32px;
        height: parent.height;
        text: root.value;
        color: #f4f4f5;
        vertical-alignment: center;
    }

    Text {
        x: parent.width - 22px;
        y: 0px;
        width: 16px;
        height: parent.height;
        text: "v";
        color: #a1a1aa;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // Popup is one bordered panel with contiguous rows, so choices look attached.
    popup := PopupWindow {
        width: root.width;
        height: 108px;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #18181b;
            border-color: #52525b;
            border-width: 1px;
            border-radius: 4px;
            clip: true;

            VerticalBox {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 36px;
                    background: root.value == "right" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "right"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "right"; color: #f4f4f5; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #27272a; }
                Rectangle {
                    height: 35px;
                    background: root.value == "left" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "left"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "left"; color: #f4f4f5; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #27272a; }
                Rectangle {
                    height: 35px;
                    background: root.value == "vertical" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "vertical"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "vertical"; color: #f4f4f5; vertical-alignment: center; }
                }
            }
        }
    }
}

// Same custom combobox pattern for native host driver selection.
component DriverCombo inherits Rectangle {
    in-out property <string> value;

    height: 36px;
    min-width: 160px;
    background: #18181b;
    border-color: #52525b;
    border-width: 1px;
    border-radius: 4px;

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { popup.show(); }
    }

    Text {
        x: 10px;
        y: 0px;
        width: parent.width - 32px;
        height: parent.height;
        text: root.value;
        color: #f4f4f5;
        vertical-alignment: center;
    }

    Text {
        x: parent.width - 22px;
        y: 0px;
        width: 16px;
        height: parent.height;
        text: "v";
        color: #a1a1aa;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    popup := PopupWindow {
        width: root.width;
        height: 180px;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #18181b;
            border-color: #52525b;
            border-width: 1px;
            border-radius: 4px;
            clip: true;

            VerticalBox {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    height: 36px;
                    background: root.value == "auto" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "auto"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "auto"; color: #f4f4f5; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #27272a; }
                Rectangle {
                    height: 35px;
                    background: root.value == "enigo" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "enigo"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "enigo"; color: #f4f4f5; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #27272a; }
                Rectangle {
                    height: 35px;
                    background: root.value == "uinput" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "uinput"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "uinput"; color: #f4f4f5; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #27272a; }
                Rectangle {
                    height: 35px;
                    background: root.value == "uinput-tablet" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "uinput-tablet"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "uinput-tablet"; color: #f4f4f5; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #27272a; }
                Rectangle {
                    height: 35px;
                    background: root.value == "windows-pen" ? #3f3f46 : #18181b;
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.value = "windows-pen"; popup.close(); } }
                    Text { x: 10px; width: parent.width - 20px; height: parent.height; text: "windows-pen"; color: #f4f4f5; vertical-alignment: center; }
                }
            }
        }
    }
}

component MonitorCombo inherits Rectangle {
    in property <[string]> options;
    in-out property <int> selected-index;

    height: 36px;
    min-width: 320px;
    background: #18181b;
    border-color: #52525b;
    border-width: 1px;
    border-radius: 4px;

    TouchArea { width: parent.width; height: parent.height; clicked => { popup.show(); } }
    Text {
        x: 10px;
        width: parent.width - 32px;
        height: parent.height;
        text: root.options.length > 0 ? root.options[root.selected-index] : "No monitors found";
        color: #f4f4f5;
        vertical-alignment: center;
        overflow: elide;
    }
    Text {
        x: parent.width - 22px;
        width: 16px;
        height: parent.height;
        text: "v";
        color: #a1a1aa;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    popup := PopupWindow {
        width: root.width;
        height: root.options.length * 36px;
        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #18181b;
            border-color: #52525b;
            border-width: 1px;
            border-radius: 4px;
            clip: true;
            VerticalBox {
                padding: 0px;
                spacing: 0px;
                for option[index] in root.options: Rectangle {
                    height: 36px;
                    background: root.selected-index == index ? #3f3f46 : #18181b;
                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => { root.selected-index = index; popup.close(); }
                    }
                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        text: option;
                        color: #f4f4f5;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }
}

export component RemouseableWindow inherits Window {
    title: "reMouseable";
    icon: @image-url("../assets/remouseable.png");
    min-width: 520px;
    min-height: 620px;

    in-out property <string> ssh-ip: "10.11.99.1:22";
    in-out property <string> ssh-user: "root";
    in-out property <string> ssh-password: "";
    in-out property <string> event-file: "/dev/input/event1";
    in-out property <string> orientation: "right";
    in-out property <string> host-driver: "auto";
    in property <[string]> monitor-options;
    in-out property <int> monitor-index: 0;
    in property <bool> show-monitor-selector: false;
    in-out property <float> windows-pen-interval-ms: 5;
    in-out property <string> pressure-threshold: "1000";
    in-out property <bool> disable-drag-event: false;
    in-out property <bool> running: false;
    in-out property <string> status-text: "Ready";

    // Rust handles long-running work. Slint only emits user intent with current
    // control values.
    callback start-requested(string, string, string, string, string, string, int, float, string, bool);
    callback stop-requested();

    background: #09090b;

    VerticalBox {
        padding: 20px;
        spacing: 14px;

        Text {
            text: "reMouseable";
            font-size: 28px;
            font-weight: 700;
            color: #fafafa;
        }

        Text {
            text: "Connect a reMarkable tablet and stream stylus events to the host mouse.";
            color: #a1a1aa;
            wrap: word-wrap;
        }

        Rectangle {
            height: 1px;
            background: #3f3f46;
        }

        Text { text: "Connection"; font-weight: 700; color: #f4f4f5; }

        Text { text: "SSH address"; color: #d4d4d8; }
        ReadableLineEdit { text <=> root.ssh-ip; placeholder-text: "10.11.99.1:22"; }

        Text { text: "SSH user"; color: #d4d4d8; }
        ReadableLineEdit { text <=> root.ssh-user; placeholder-text: "root"; }

        Text { text: "SSH password"; color: #d4d4d8; }
        ReadableLineEdit {
            text <=> root.ssh-password;
            placeholder-text: "Tablet password";
            input-type: InputType.password;
            accepted => {
                if (!root.running) {
                    root.start-requested(
                        root.ssh-ip,
                        root.ssh-user,
                        root.ssh-password,
                        root.event-file,
                        root.orientation,
                        root.host-driver,
                        root.monitor-index,
                        root.windows-pen-interval-ms,
                        root.pressure-threshold,
                        root.disable-drag-event,
                    );
                }
            }
        }

        Text { text: "Event file"; color: #d4d4d8; }
        ReadableLineEdit { text <=> root.event-file; placeholder-text: "/dev/input/event1"; }

        Text { text: "Behavior"; font-weight: 700; color: #f4f4f5; }

        // Start/Stop are custom buttons so label colors stay theme-controlled.
        HorizontalBox {
            spacing: 12px;

            VerticalBox {
                Text { text: "Orientation"; color: #d4d4d8; }
                OrientationCombo { value <=> root.orientation; }
            }

            VerticalBox {
                Text { text: "Host driver"; color: #d4d4d8; }
                DriverCombo { value <=> root.host-driver; }
            }
        }

        VerticalBox {
            visible: root.show-monitor-selector && (root.host-driver == "auto" || root.host-driver == "windows-pen");
            Text { text: "Input mapping monitor"; color: #d4d4d8; }
            MonitorCombo { options: root.monitor-options; selected-index <=> root.monitor-index; }
        }

        VerticalBox {
            visible: root.show-monitor-selector && (root.host-driver == "auto" || root.host-driver == "windows-pen");
            Text {
                text: "Windows pen update interval: " + round(root.windows-pen-interval-ms) + " ms";
                color: #d4d4d8;
            }
            Slider {
                minimum: 1;
                maximum: 20;
                step: 1;
                value <=> root.windows-pen-interval-ms;
            }
            Text {
                text: "Lower values improve accuracy and latency but increase CPU/input load and may reduce stability. Higher values reduce load but add latency.";
                color: #a1a1aa;
                wrap: word-wrap;
            }
        }

        Text { text: "Pressure threshold"; color: #d4d4d8; }
        ReadableLineEdit { text <=> root.pressure-threshold; placeholder-text: "1000"; }

        // Switch {
        //     text: "Disable custom drag event";
        //     checked <=> root.disable-drag-event;
        // }

        Rectangle {
            height: 1px;
            background: #3f3f46;
        }

        HorizontalBox {
            spacing: 12px;

            Rectangle {
                width: 96px;
                height: 36px;
                background: root.running ? #27272a : start-touch.pressed ? #52525b : #e4e4e7;
                border-color: #71717a;
                border-width: 1px;
                border-radius: 4px;

                start-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    enabled: !root.running;
                    clicked => {
                        root.start-requested(
                            root.ssh-ip,
                            root.ssh-user,
                            root.ssh-password,
                            root.event-file,
                            root.orientation,
                            root.host-driver,
                            root.monitor-index,
                            root.windows-pen-interval-ms,
                            root.pressure-threshold,
                            root.disable-drag-event,
                        );
                    }
                }

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: root.running ? "Running" : "Start";
                    color: root.running ? #71717a : #09090b;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                width: 96px;
                height: 36px;
                background: root.running ? stop-touch.pressed ? #52525b : #e4e4e7 : #27272a;
                border-color: #71717a;
                border-width: 1px;
                border-radius: 4px;

                stop-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    enabled: root.running;
                    clicked => {
                        root.stop-requested();
                    }
                }

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: "Stop";
                    color: root.running ? #09090b : #71717a;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: root.status-text;
            color: root.running ? #fafafa : #a1a1aa;
            wrap: word-wrap;
        }
    }
}
